FROM node:18-alpine

WORKDIR /app

COPY package.json ./
RUN npm install --omit=dev --no-audit --no-fund

COPY server.js ./
COPY widgets/ ./widgets/
COPY themes/ ./themes/

# Data directory wordt door de gebruiker gemount; aanmaken als fallback
RUN mkdir -p /app/data

EXPOSE 3000

CMD ["node", "server.js"]
